# RPC provider — one of: infura, alchemy, custom
# If unset, the MCP server falls back to ~/.recon-crypto-mcp/config.json (written by `recon-crypto-mcp-setup`).
RPC_PROVIDER=infura

# API key for the chosen provider (unused when RPC_PROVIDER=custom)
RPC_API_KEY=

# Only used when RPC_PROVIDER=custom — full RPC URLs per chain
ETHEREUM_RPC_URL=
ARBITRUM_RPC_URL=

# Optional — for contract verification checks (Module 2 / Security)
# Free tier works without a key but at 1 req / 5s. A key lifts this to 5 req/s.
ETHERSCAN_API_KEY=

# Optional — WalletConnect Cloud project ID. A default one is bundled but you
# can provide your own for production deployments.
WALLETCONNECT_PROJECT_ID=
